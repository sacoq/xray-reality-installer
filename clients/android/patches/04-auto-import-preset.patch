@@ -84,6 +87,35 @@ Future<void> lazyBootstrap(WidgetsBinding widgetsBinding, Environment env) async
 
   await _init("profile repository", () => container.read(profileRepositoryProvider.future));
 
+  await _safeInit("preset subscription", () async {
+    final url = WhitelabelConfig.presetSubscriptionUrl;
+    if (url.isEmpty) {
+      Logger.bootstrap.debug("no preset subscription URL, skipping auto-import");
+      return;
+    }
+    final repo = container.read(profileRepositoryProvider).requireValue;
+    final hasAny = await repo.watchHasAnyProfile().first;
+    final hasProfile = hasAny.match((_) => false, (b) => b);
+    if (hasProfile) {
+      Logger.bootstrap.debug("preset: profiles already present, skipping");
+      return;
+    }
+    Logger.bootstrap.info("preset: importing $url");
+    await repo
+        .upsertRemote(url, userOverride: UserOverride(name: WhitelabelConfig.brandName))
+        .match(
+          (err) {
+            Logger.bootstrap.warning("preset: import failed: $err");
+            return null;
+          },
+          (_) {
+            Logger.bootstrap.info("preset: imported successfully");
+            return null;
+          },
+        )
+        .run();
+  });
+
   await _init("translations", () => container.read(translationsProvider.future));
 
   await _safeInit("active profile", () => container.read(activeProfileProvider.future), timeout: 1000);
