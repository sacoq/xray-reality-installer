#!/usr/bin/env bash
# xnpanel — management CLI for xray-reality-installer (xnPanel).
#
# Refreshes the panel + agent Python sources from the upstream GitHub
# repository (commit-level, not OS-level) and restarts the corresponding
# services. Also exposes a cheap "check" subcommand used by a systemd
# timer to populate the MOTD banner shown on SSH login.
#
# Deliberately does NOT re-run install.sh: the installer regenerates
# Reality keys / panel secrets / the xray config, which would break
# every live client. `xnpanel update` only touches panel/ and agent/
# code trees + their Python deps.

set -Eeuo pipefail

readonly REPO="sacoq/xray-reality-installer"
readonly DEFAULT_BRANCH="main"
BRANCH="${XNPANEL_BRANCH:-$DEFAULT_BRANCH}"

readonly STATE_DIR="/etc/xnpanel"
readonly CACHE_DIR="/var/lib/xnpanel"
readonly VERSION_FILE="${STATE_DIR}/version"
readonly UPDATE_CACHE="${CACHE_DIR}/update-available"

readonly PANEL_ROOT="/opt/xray-panel"
readonly PANEL_CODE="${PANEL_ROOT}/panel"
readonly PANEL_VENV="${PANEL_ROOT}/venv"
readonly AGENT_ROOT="/opt/xray-agent"
readonly AGENT_CODE="${AGENT_ROOT}/agent"
readonly AGENT_VENV="${AGENT_ROOT}/venv"

# ---------- output helpers ----------
if [[ -t 1 ]]; then
    C_RESET=$'\033[0m'
    C_RED=$'\033[31m'
    C_GREEN=$'\033[32m'
    C_YELLOW=$'\033[33m'
    C_BLUE=$'\033[34m'
    C_BOLD=$'\033[1m'
else
    C_RESET=""; C_RED=""; C_GREEN=""; C_YELLOW=""; C_BLUE=""; C_BOLD=""
fi

log()  { printf '%s[*]%s %s\n' "$C_BLUE"  "$C_RESET" "$*"; }
ok()   { printf '%s[+]%s %s\n' "$C_GREEN" "$C_RESET" "$*"; }
warn() { printf '%s[!]%s %s\n' "$C_YELLOW" "$C_RESET" "$*" >&2; }
die()  { printf '%s[x]%s %s\n' "$C_RED"   "$C_RESET" "$*" >&2; exit 1; }

require_root() {
    if [[ $EUID -ne 0 ]]; then
        die "this command must run as root (try: sudo xnpanel $1)"
    fi
}

short() { printf '%s' "${1:0:7}"; }

# ---------- version file parsing ----------
current_sha() {
    [[ -r "$VERSION_FILE" ]] || return 0
    awk -F= '/^COMMIT=/ {print $2; exit}' "$VERSION_FILE"
}

current_installed_ts() {
    [[ -r "$VERSION_FILE" ]] || return 0
    awk -F= '/^INSTALLED_AT=/ {print $2; exit}' "$VERSION_FILE"
}

installed_mode() {
    if [[ -d "$PANEL_CODE" ]]; then
        echo panel
    elif [[ -d "$AGENT_CODE" ]]; then
        echo node
    elif [[ -x /usr/local/bin/xray ]]; then
        echo standalone
    else
        echo unknown
    fi
}

# ---------- remote SHA ----------
remote_sha() {
    # Ask the GitHub REST API for the tip of ${BRANCH}. Uses curl only —
    # this CLI is invoked by the timer on boxes where jq may not be
    # present, so we grep as a fallback.
    local resp
    resp="$(curl -fsSL --max-time 10 \
        -H 'Accept: application/vnd.github.v3+json' \
        "https://api.github.com/repos/${REPO}/commits/${BRANCH}" 2>/dev/null)" || return 1
    if [[ -z "$resp" ]]; then
        return 1
    fi
    local sha=""
    if command -v jq >/dev/null 2>&1; then
        sha="$(printf '%s' "$resp" | jq -r '.sha // empty' 2>/dev/null || true)"
    fi
    if [[ -z "$sha" ]]; then
        # Portable fallback for boxes without jq: capture the *value*
        # of the first top-level "sha" field. sed handles the extraction
        # more reliably than chaining two greps (which would match the
        # letter 'a' inside "sha" before reaching the real SHA run).
        sha="$(printf '%s' "$resp" \
            | sed -n 's/.*"sha"[[:space:]]*:[[:space:]]*"\([0-9a-f][0-9a-f]*\)".*/\1/p' \
            | head -n1)"
    fi
    [[ -n "$sha" ]] || return 1
    printf '%s' "$sha"
}

# ---------- update check ----------
# Populates globals UPDATE_STATUS / UPDATE_CUR / UPDATE_LATEST and writes
# $UPDATE_CACHE for the MOTD to consume.
UPDATE_STATUS=""
UPDATE_CUR=""
UPDATE_LATEST=""

check_update() {
    UPDATE_CUR="$(current_sha || true)"
    UPDATE_LATEST=""
    if ! UPDATE_LATEST="$(remote_sha 2>/dev/null)"; then
        UPDATE_STATUS="unknown"
    elif [[ -z "$UPDATE_CUR" ]]; then
        # CLI present but no recorded install version. Treat as update
        # available so the admin gets prompted to re-install via the
        # tracked branch and thereby backfill the version file.
        UPDATE_STATUS="available"
    elif [[ "$UPDATE_CUR" == "$UPDATE_LATEST" ]]; then
        UPDATE_STATUS="uptodate"
    else
        UPDATE_STATUS="available"
    fi

    # Cache result for MOTD. Best-effort; CLI invoked by unprivileged
    # callers (status subcommand) simply won't update the cache.
    if mkdir -p "$CACHE_DIR" 2>/dev/null; then
        umask 022
        if {
            printf 'STATUS=%s\n'     "$UPDATE_STATUS"
            printf 'CURRENT=%s\n'    "$UPDATE_CUR"
            printf 'LATEST=%s\n'     "$UPDATE_LATEST"
            printf 'BRANCH=%s\n'     "$BRANCH"
            printf 'CHECKED_AT=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        } > "${UPDATE_CACHE}.tmp" 2>/dev/null; then
            mv "${UPDATE_CACHE}.tmp" "$UPDATE_CACHE" 2>/dev/null || true
        fi
    fi
}

cmd_check() {
    local quiet=0
    if [[ "${1:-}" == "--quiet" || "${1:-}" == "-q" ]]; then
        quiet=1
    fi
    check_update
    if [[ "$quiet" -eq 1 ]]; then
        return 0
    fi
    case "$UPDATE_STATUS" in
        uptodate)
            ok "xnPanel up to date ($(short "$UPDATE_CUR"))"
            ;;
        available)
            printf '%sNew xnPanel version available on branch %s%s\n' \
                "$C_BOLD" "$BRANCH" "$C_RESET"
            printf '  installed : %s\n' "${UPDATE_CUR:+$(short "$UPDATE_CUR")}"
            printf '  latest    : %s\n' "${UPDATE_LATEST:+$(short "$UPDATE_LATEST")}"
            printf '  upgrade   : sudo xnpanel update\n'
            ;;
        unknown|*)
            warn "could not reach GitHub to check for updates"
            return 1
            ;;
    esac
}

# ---------- download ----------
ensure_git() {
    if command -v git >/dev/null 2>&1; then return; fi
    if command -v apt-get >/dev/null 2>&1; then
        apt-get update -qq >/dev/null 2>&1 || true
        apt-get install -y --no-install-recommends git >/dev/null 2>&1 || true
    fi
    command -v git >/dev/null 2>&1 || die "git is required to fetch updates"
}

download_sources() {
    ensure_git
    local tmpdir
    tmpdir="$(mktemp -d -t xnpanel-update.XXXXXXXX)"
    git clone --depth 1 --branch "$BRANCH" \
        "https://github.com/${REPO}.git" "$tmpdir/src" >/dev/null 2>&1 \
        || { rm -rf "$tmpdir"; die "git clone failed (branch=${BRANCH})"; }
    printf '%s' "$tmpdir/src"
}

# ---------- update one component ----------
# args: <name> <dest_root> <code_dir> <venv> <src_root> <systemd_unit>
update_component() {
    local name="$1" dest_root="$2" code_dir="$3" venv="$4" src="$5" service="$6"
    local src_sub="${src}/${name}"
    [[ -d "$src_sub" ]] || die "source ${src_sub} missing in upstream checkout"

    log "syncing ${name} source → ${code_dir}"
    install -d -m 0755 "$dest_root"
    rm -rf "${code_dir}.new"
    cp -r "$src_sub" "${code_dir}.new"

    # Swap atomically so a failed restart leaves the previous good
    # copy behind at ${code_dir}.old for easy rollback.
    if [[ -d "$code_dir" ]]; then
        rm -rf "${code_dir}.old"
        mv "$code_dir" "${code_dir}.old"
    fi
    mv "${code_dir}.new" "$code_dir"

    if [[ -x "${venv}/bin/pip" && -r "${code_dir}/requirements.txt" ]]; then
        log "updating ${name} python deps"
        "${venv}/bin/pip" install --quiet --upgrade pip
        "${venv}/bin/pip" install --quiet -r "${code_dir}/requirements.txt"
    fi

    if systemctl list-unit-files 2>/dev/null | grep -q "^${service}"; then
        log "restarting ${service}"
        systemctl restart "$service" || warn "failed to restart ${service}"
    fi
    # Drop the rollback copy on success. Deliberately done last so a
    # mid-restart crash above preserves ${code_dir}.old for the admin.
    rm -rf "${code_dir}.old" 2>/dev/null || true
}

install_cli_from_source() {
    local src="$1"
    if [[ -r "${src}/bin/xnpanel" ]]; then
        install -m 0755 "${src}/bin/xnpanel" /usr/local/bin/xnpanel
    fi
    # The MOTD snippet is Ubuntu/Debian-only (pam_motd + update-motd.d).
    # On RHEL/CentOS/Rocky/Alma/Fedora the directory doesn't exist and
    # the old `install` call aborted the whole `xnpanel update`. Create
    # the directory on the fly; if the distro doesn't wire pam_motd
    # into its login stack the file just sits there as dead weight,
    # which is harmless — we'd rather have that than a broken update.
    if [[ -r "${src}/bin/xnpanel-motd" ]]; then
        if [[ ! -d /etc/update-motd.d ]]; then
            mkdir -p /etc/update-motd.d 2>/dev/null || {
                warn "cannot create /etc/update-motd.d; skipping MOTD banner"
                return 0
            }
        fi
        install -m 0755 "${src}/bin/xnpanel-motd" /etc/update-motd.d/90-xnpanel-update
    fi
}

save_version_file() {
    local sha="$1"
    install -d -m 0755 "$STATE_DIR"
    umask 022
    {
        [[ -n "$sha" ]] && printf 'COMMIT=%s\n' "$sha"
        printf 'BRANCH=%s\n' "$BRANCH"
        printf 'INSTALLED_AT=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    } > "${VERSION_FILE}.tmp"
    mv "${VERSION_FILE}.tmp" "$VERSION_FILE"
}

# ---------- subcommands ----------
cmd_update() {
    require_root update
    local force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            -h|--help)
                cat <<EOF
Usage: xnpanel update [--force]
  Pull the latest panel/agent sources from ${BRANCH} and restart the
  services. Does NOT regenerate Reality keys or panel secrets.
  With --force: re-sync even when the installed commit already matches.
EOF
                return 0
                ;;
            *) die "unknown flag for update: $1" ;;
        esac
    done

    check_update
    if [[ "$UPDATE_STATUS" == "unknown" ]]; then
        die "could not reach GitHub (check network). Try again later."
    fi
    if [[ "$UPDATE_STATUS" == "uptodate" && "$force" -eq 0 ]]; then
        ok "already up to date ($(short "$UPDATE_CUR")). Pass --force to re-sync."
        return 0
    fi

    log "fetching sources from github.com/${REPO}@${BRANCH}"
    local src
    src="$(download_sources)"
    local scratch
    scratch="$(dirname "$src")"
    # shellcheck disable=SC2064
    trap "rm -rf '$scratch'" EXIT

    local new_sha
    new_sha="$(git -C "$src" rev-parse HEAD 2>/dev/null || true)"
    [[ -n "$new_sha" ]] || new_sha="${UPDATE_LATEST:-}"
    if [[ -n "$new_sha" ]]; then
        log "target commit: $(short "$new_sha")"
    fi

    local mode
    mode="$(installed_mode)"
    case "$mode" in
        panel)
            update_component agent "$AGENT_ROOT" "$AGENT_CODE" "$AGENT_VENV" "$src" xray-agent.service
            update_component panel "$PANEL_ROOT" "$PANEL_CODE" "$PANEL_VENV" "$src" xray-panel.service
            ;;
        node)
            update_component agent "$AGENT_ROOT" "$AGENT_CODE" "$AGENT_VENV" "$src" xray-agent.service
            ;;
        standalone)
            warn "standalone xray install detected — no panel/agent to update."
            warn "to upgrade xray itself, re-run install.sh from ${REPO}."
            ;;
        unknown|*)
            die "could not determine current installation mode (panel/node/standalone)"
            ;;
    esac

    install_cli_from_source "$src"
    save_version_file "$new_sha"
    # Refresh update cache so MOTD clears immediately.
    check_update

    ok "xnPanel updated${new_sha:+ to $(short "$new_sha")}"
}

cmd_version() {
    local cur mode ts
    cur="$(current_sha || true)"
    mode="$(installed_mode)"
    ts="$(current_installed_ts || true)"
    printf 'xnpanel CLI\n'
    printf '  repo         : https://github.com/%s (branch %s)\n' "$REPO" "$BRANCH"
    printf '  mode         : %s\n' "$mode"
    if [[ -n "$cur" ]]; then
        printf '  installed    : %s\n' "$(short "$cur")"
    else
        printf '  installed    : (not recorded)\n'
    fi
    [[ -n "$ts" ]] && printf '  installed at : %s\n' "$ts"
}

cmd_status() {
    local mode
    mode="$(installed_mode)"
    printf 'mode : %s\n' "$mode"
    local svc
    for svc in xray xray-agent xray-panel; do
        if systemctl list-unit-files 2>/dev/null | grep -q "^${svc}.service"; then
            printf '  %-11s : %s\n' "$svc" "$(systemctl is-active "$svc" 2>/dev/null || echo unknown)"
        fi
    done
    echo
    # Silently attempt a check so the status subcommand is useful even
    # without network — it prints a warning in that case.
    cmd_check || true
}

cmd_restart() {
    require_root restart
    local svc
    for svc in xray xray-agent xray-panel; do
        if systemctl list-unit-files 2>/dev/null | grep -q "^${svc}.service"; then
            log "restart ${svc}"
            systemctl restart "$svc" || warn "restart ${svc} failed"
        fi
    done
    ok "services restarted"
}

cmd_logs() {
    local target="${1:-panel}"
    local unit=""
    case "$target" in
        panel)  unit="xray-panel" ;;
        agent)  unit="xray-agent" ;;
        xray)   unit="xray" ;;
        -h|--help)
            echo "Usage: xnpanel logs [panel|agent|xray]"
            return 0
            ;;
        *) die "unknown target: ${target} (expected: panel|agent|xray)" ;;
    esac
    journalctl -u "$unit" --no-pager -n 200
}

usage() {
    cat <<EOF
xnpanel — xnPanel management CLI

Usage: xnpanel <command> [args]

Commands:
  update [--force]    Pull latest panel/agent sources from ${DEFAULT_BRANCH}
                      and restart the services.
  check [--quiet]     Check whether a new release is available upstream.
  version             Show the installed commit + mode.
  status              Show panel/agent service status + update check.
  restart             Restart xray / xray-agent / xray-panel.
  logs <unit>         Tail journal for panel | agent | xray.
  help                Show this help.

Environment:
  XNPANEL_BRANCH      Branch to track (default: ${DEFAULT_BRANCH}).

Examples:
  sudo xnpanel update
  xnpanel check
  xnpanel logs panel
EOF
}

main() {
    case "${1:-help}" in
        update)        shift; cmd_update "$@" ;;
        check)         shift; cmd_check "$@" ;;
        version|-V|--version) cmd_version ;;
        status)        cmd_status ;;
        restart)       cmd_restart ;;
        logs)          shift; cmd_logs "${1:-panel}" ;;
        help|-h|--help) usage ;;
        *)             usage; exit 1 ;;
    esac
}

main "$@"
